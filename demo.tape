# peasy-pdf-rb — PDF merge, split, rotate, compress (Ruby)
# Theme: Rose Pine
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "rose-pine"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-pdf-rb — PDF merge, split, rotate, compress for Ruby"
Enter
Type "# peasypdf.com"
Enter
Sleep 500ms

# Run the demo
Type "ruby -I lib examples/demo.rb"
Enter
Sleep 5s
